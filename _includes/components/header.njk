<header class="sb-header">
  <a class="sb-wordmark" href="/">Spamboy</a>

  <button class="sb-hamburger" type="button" aria-label="Open menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>

  <nav class="sb-mobile-menu" aria-label="Main navigation">
    {% for item in site.nav %}
    {#- Only render the link if a published page actually exists at this URL.
        Drafts are absent from collections in production, so their nav links
        disappear automatically (and remain during local serve for preview). -#}
    {%- for p in collections.all %}{% if p.url == item.url %}
    {% set isActive = page.url and (page.url == item.url or (item.url != "/" and page.url.startsWith(item.url))) %}
    <a href="{{ item.url }}"{% if isActive %} class="is-active" aria-current="page"{% endif %}>{{ item.label }}</a>
    {% endif %}{% endfor %}
    {% endfor %}
    <div class="sb-mobile-theme">
      <button class="sb-theme-toggle" data-theme-toggle type="button" aria-label="Toggle colour theme">
        <svg class="sb-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
        <svg class="sb-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <span data-theme-label>Dark</span>
      </button>
    </div>
  </nav>
</header>
